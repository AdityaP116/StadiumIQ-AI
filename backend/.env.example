# StadiumIQ Environment Variables
# Copy this file to .env and fill in all values before running the server.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Firebase Admin ────────────────────────────────────────────────────────────
# Ensure you generate a new private key from your Firebase project settings -> Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourKeyHere\n-----END PRIVATE KEY-----\n"


# ─── AI Provider ──────────────────────────────────────────────────────────────
# AI Provider (Current: NVIDIA NIM via OpenAI SDK)
NVIDIA_API_KEY=nvapi-your-key-here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your frontend URL in production (e.g., https://stadium-iq-ai-phi.vercel.app)
# Use * for development only
CLIENT_URL=https://stadium-iq-ai-phi.vercel.app
